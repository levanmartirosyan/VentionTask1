{
  "ReverseProxy": {
    "Routes": {
      "main-api-route": {
        "ClusterId": "main-api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "main-api": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7269/"
          }
        }
      }
    }
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "",
    "Audience": "",
    "ExpiryMinutes": 1440
  },
  "MainApi": {
    "BaseUrl": "https://localhost:7269"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
